{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deactivate Contract",
  "description": "Suspends a contract. Only the receiver node may call this.",
  "type": "object",
  "required": ["_func", "contract_id"],
  "properties": {
    "_func": {
      "type": "string",
      "const": "deactivate_contract"
    },
    "contract_id": {
      "type": "string",
      "format": "uuid"
    }
  },
  "additionalProperties": false
}
